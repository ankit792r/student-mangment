# --------------------------
# Compose
# --------------------------
COMPOSE_PROJECT_NAME=bonefire-dev

# Images
FRONTEND_IMAGE=bonefire-frontend:dev
BACKEND_IMAGE=bonefire-backend:dev

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --------------------------
# MongoDB
# --------------------------
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root
MONGO_DATABASE=backend

# --------------------------
# Mongo Express
# --------------------------
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_PORT=27017

ME_CONFIG_MONGODB_ADMINUSERNAME=root
ME_CONFIG_MONGODB_ADMINPASSWORD=root

ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin

# --------------------------
# Valkey
# --------------------------
VALKEY_HOST=valkey
VALKEY_PORT=6379

# --------------------------
# Backend Overrides
# --------------------------
# Docker service name is used instead of localhost
MONGODB_URI=mongodb://root:root@mongodb:27017/bonefire?authSource=admin
VALKEY_URI=redis://valkey:6379

